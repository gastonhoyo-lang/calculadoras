---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
// Variables para evitar conflictos con llaves en Astro
const sVentas = "Ventas Brutas Totales";
const sCostosOperativos = "Costos Operativos";
const sMargenNeto = "Margen Neto Ecommerce";

// Fórmulas en LaTeX
const fRentabilidadEcommerce =
  "$$ Rentabilidad\\ Neta\\ = \\frac{Ventas\\ Brutas - (COGS + Gastos\\ Op + Marketing + Logística)}{Ventas\\ Brutas} \\times 100 $$";
const fRatioEficiencia =
  "$$ Ratio\\ de\\ Eficiencia\\ = \\frac{Gastos\\ de\\ Marketing}{Ventas\\ Totales} $$";
---

<Layout
  title="Calculadora de Rentabilidad de Ecommerce | Análisis Financiero Pro"
  description="Calcula la rentabilidad neta de tu tienda online. Guía completa sobre márgenes de ecommerce, costos ocultos, ROAS y eficiencia operativa."
>
  <main class="max-w-5xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1
        class="text-4xl md:text-6xl font-black text-slate-900 mb-4 tracking-tight"
      >
        Calculadora de <span class="text-cyan-600">Rentabilidad Ecommerce</span> 🚀
      </h1>
      <p
        class="text-slate-500 text-lg font-medium max-w-2xl mx-auto text-balance"
      >
        Analiza la salud financiera global de tu tienda online y descubre cuánto
        dinero queda realmente en tu bolsillo.
      </p>
    </header>

    <section
      class="bg-white p-6 md:p-12 rounded-[3rem] border border-slate-100 shadow-2xl max-w-4xl mx-auto mb-20"
    >
      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <div class="space-y-4">
          <label
            for="ecoVentas"
            class="block text-xs font-bold text-slate-400 uppercase tracking-widest ml-2"
            >Facturación Total (Ventas Brutas)</label
          >
          <input
            type="number"
            id="ecoVentas"
            placeholder="Ej: 50000"
            class="w-full p-4 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-cyan-500 outline-none transition-all shadow-inner font-bold"
          />
        </div>
        <div class="space-y-4">
          <label
            for="ecoCogs"
            class="block text-xs font-bold text-slate-400 uppercase tracking-widest ml-2"
            >Costo de Mercancía (COGS)</label
          >
          <input
            type="number"
            id="ecoCogs"
            placeholder="Ej: 20000"
            class="w-full p-4 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-cyan-500 outline-none transition-all shadow-inner font-bold"
          />
        </div>
        <div class="space-y-4">
          <label
            for="ecoMarketing"
            class="block text-xs font-bold text-slate-400 uppercase tracking-widest ml-2"
            >Inversión en Ads y Marketing</label
          >
          <input
            type="number"
            id="ecoMarketing"
            placeholder="Ej: 8000"
            class="w-full p-4 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-cyan-500 outline-none transition-all shadow-inner font-bold"
          />
        </div>
        <div class="space-y-4">
          <label
            for="ecoOpEx"
            class="block text-xs font-bold text-slate-400 uppercase tracking-widest ml-2"
            >Gastos Operativos (Software, Sueldos, Alquiler)</label
          >
          <input
            type="number"
            id="ecoOpEx"
            placeholder="Ej: 5000"
            class="w-full p-4 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-cyan-500 outline-none transition-all shadow-inner font-bold"
          />
        </div>
      </div>

      <button
        id="btnEcoCalc"
        class="w-full bg-slate-900 text-white p-6 rounded-[2rem] font-bold hover:bg-cyan-600 transition-all shadow-lg active:scale-95 text-xl"
      >
        Analizar Salud del Ecommerce
      </button>

      <div
        id="ecoResultBox"
        class="hidden mt-10 space-y-4 animate-in fade-in slide-in-from-bottom-4 duration-500"
      >
        <div
          class="bg-cyan-50 p-10 rounded-[2.5rem] border border-cyan-100 text-center"
        >
          <span
            class="block text-xs font-bold text-cyan-400 uppercase mb-2 tracking-widest"
            >Rentabilidad Neta (Margen Final)</span
          >
          <span id="resEcoRent" class="block text-6xl font-black text-cyan-700"
            >0%</span
          >
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-slate-50 p-6 rounded-3xl text-center">
            <span
              id="resEcoProfit"
              class="block text-xl font-bold text-slate-800">$0</span
            >
            <span
              class="text-[10px] font-bold text-slate-400 uppercase tracking-widest"
              >Beneficio Neto Real</span
            >
          </div>
          <div class="bg-slate-50 p-6 rounded-3xl text-center">
            <span
              id="resEcoCostPer"
              class="block text-xl font-bold text-slate-800">0%</span
            >
            <span
              class="text-[10px] font-bold text-slate-400 uppercase tracking-widest"
              >Peso del Marketing s/ Ventas</span
            >
          </div>
        </div>
      </div>
    </section>

    <article
      class="prose prose-slate max-w-none border-t border-slate-200 pt-16 text-slate-700 font-light leading-relaxed"
    >
      <h2 class="text-3xl font-black text-slate-900 mb-6 italic">
        Rentabilidad en Ecommerce: Más allá de las Ventas de Vanidad
      </h2>

      <p class="mb-6">
        En el mundo del comercio electrónico, es muy común caer en la trampa de
        las "métricas de vanidad". Ver un panel de control con miles de dólares
        en ventas brutas puede ser emocionante, pero la verdadera pregunta es: <strong
          >¿cuánto de ese dinero queda realmente en tu cuenta bancaria?</strong
        > La rentabilidad de un ecommerce es el indicador definitivo que separa a
        los negocios escalables de los que están a un paso de la insolvencia.
      </p>

      <p class="mb-6">
        A diferencia del retail tradicional, el ecommerce enfrenta una
        estructura de costos dinámica. Tenemos la inversión en publicidad
        digital (Facebook Ads, Google Shopping), las comisiones de pasarelas de
        pago, los costos logísticos de última milla y, lo más peligroso, la tasa
        de devoluciones. Sin un cálculo preciso de la rentabilidad neta, un
        aumento en las ventas podría, paradójicamente, resultar en mayores
        pérdidas si el costo de adquisición de clientes es demasiado elevado.
      </p>

      <h3 class="text-2xl font-bold text-slate-800 mb-4">
        Los Pilares de la Rentabilidad Neta
      </h3>
      <p class="mb-6">
        Para entender la salud de tu tienda, debemos desglosar la cuenta de
        resultados en cuatro bloques fundamentales:
      </p>
      <ul class="list-disc pl-6 mb-8 space-y-4">
        <li>
          <strong>COGS (Cost of Goods Sold):</strong> Es el costo directo de la mercancía.
          Si fabricas, incluye materia prima; si haces dropshipping o retail, es el
          costo de compra al proveedor.
        </li>
        <li>
          <strong>Costos de Adquisición (Marketing):</strong> En ecommerce, este suele
          ser el gasto más volátil. Incluye la inversión en anuncios, agencias y herramientas
          de SEO.
        </li>
        <li>
          <strong>Costos Operativos (OpEx):</strong> El mantenimiento de tu plataforma
          (Shopify, WooCommerce), los salarios del equipo, el alquiler de almacenes
          y los servicios básicos.
        </li>
        <li>
          <strong>Logística y Comisiones:</strong> Todo lo que ocurre desde que el
          cliente hace clic en "comprar" hasta que recibe el paquete, incluyendo el
          packing y la comisión de Stripe o PayPal.
        </li>
      </ul>

      <h3 class="text-2xl font-bold text-slate-800 mb-4">
        La Fórmula Matemática de Rentabilidad
      </h3>
      <p class="mb-6">
        La rentabilidad neta se expresa como un porcentaje de las ventas
        totales. Es la "última línea" de tu reporte financiero:
      </p>

      <div
        class="bg-slate-50 p-8 rounded-3xl mb-10 border border-slate-100 text-center font-serif text-xl"
      >
        {fRentabilidadEcommerce}
      </div>

      <h3 class="text-2xl font-bold text-slate-800 mb-4">
        Variables que determinan el éxito
      </h3>
      <ul class="list-disc pl-6 mb-8 space-y-4">
        <li>
          <strong>Ventas Brutas:</strong> El total facturado sin descontar nada.
        </li>
        <li><strong>COGS:</strong> Costo directo de los productos vendidos.</li>
        <li>
          <strong>Marketing:</strong> Gasto total en captación de tráfico.
        </li>
        <li><strong>OpEx:</strong> Gastos fijos y operativos del negocio.</li>
      </ul>

      <h3 class="text-2xl font-bold text-slate-800 mb-4">
        Rentabilidad vs. ROAS: No te confundas
      </h3>
      <p class="mb-6">
        Muchos gestores de ecommerce se obsesionan con el ROAS (Retorno de la
        Inversión Publicitaria). Si invierten $1 y venden $5, dicen tener un
        ROAS de 5. Sin embargo, si el margen de producto es bajo y los costos de
        envío son altos, un ROAS de 5 podría ser insuficiente para ser rentable.
      </p>
      <p class="mb-6">
        La rentabilidad es una métrica <strong>holística</strong>, mientras que
        el ROAS es una métrica de <strong>eficiencia publicitaria</strong>.
        Puedes tener un ROAS increíble y aun así estar perdiendo dinero si tus
        costos fijos son excesivos.
      </p>

      <h2 class="text-2xl font-bold text-slate-800 mb-4">
        Casos de Uso Reales
      </h2>
      <p class="mb-6">
        <strong>1. Evaluación de Temporadas:</strong> Usar esta calculadora después
        del Black Friday te permite saber si los descuentos agresivos realmente valieron
        la pena o si solo trabajaste para mover inventario sin margen.
      </p>
      <p class="mb-6">
        <strong>2. Toma de Decisiones sobre Personal:</strong> Si tu rentabilidad
        neta es menor al 5%, quizás no es el momento de contratar a un nuevo gestor
        de redes sociales hasta optimizar el COGS o subir precios.
      </p>

      <h2 class="text-3xl font-black text-slate-900 mb-8">
        Ejemplos Prácticos de Rentabilidad Ecommerce
      </h2>

      <div class="space-y-12 mb-20">
        <div class="p-8 bg-cyan-50 rounded-[2.5rem] border border-cyan-100">
          <h3 class="text-xl font-bold text-cyan-900 mb-4">
            Ejemplo 1: Tienda de Dropshipping
          </h3>
          <p class="mb-4">
            Ventas de $10,000. Costo de productos $6,000. Gasto en Facebook Ads
            $2,500. Aplicaciones y Shopify $200.
          </p>
          <div class="bg-white p-6 rounded-2xl mb-4">
            <ul class="text-sm space-y-2">
              <li>
                <strong>Costos Totales:</strong> 6000 + 2500 + 200 = $8,700
              </li>
              <li><strong>Beneficio:</strong> $1,300</li>
              <li><strong>Cálculo:</strong> $$ (1300 / 10000) \times 100 $$</li>
              <li>
                <strong>Resultado:</strong> 13% de rentabilidad neta. Es un negocio
                saludable para dropshipping.
              </li>
            </ul>
          </div>
        </div>

        <div class="p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100">
          <h3 class="text-xl font-bold text-slate-900 mb-4">
            Ejemplo 2: Marca de Ropa Propia
          </h3>
          <p class="mb-4">
            Ventas de $50,000. COGS $15,000. Marketing $15,000. Sueldos y
            Alquiler $10,000.
          </p>
          <div class="bg-white p-6 rounded-2xl mb-4">
            <ul class="text-sm space-y-2">
              <li>
                <strong>Costos Totales:</strong> 15k + 15k + 10k = $40,000
              </li>
              <li><strong>Beneficio:</strong> $10,000</li>
              <li>
                <strong>Cálculo:</strong> $$ (10000 / 50000) \times 100 $$
              </li>
              <li>
                <strong>Resultado:</strong> 20% de rentabilidad neta. Muy sólido para
                una marca privada.
              </li>
            </ul>
          </div>
        </div>

        <div class="p-8 bg-rose-50 rounded-[2.5rem] border border-rose-100">
          <h3 class="text-xl font-bold text-rose-900 mb-4">
            Ejemplo 3: Crisis de Escalado
          </h3>
          <p class="mb-4">
            Ventas de $100,000. COGS $50,000. Marketing $45,000. Otros gastos
            $10,000.
          </p>
          <div class="bg-white p-6 rounded-2xl mb-4">
            <ul class="text-sm space-y-2">
              <li><strong>Costos Totales:</strong> $105,000</li>
              <li><strong>Beneficio:</strong> -$5,000</li>
              <li>
                <strong>Cálculo:</strong> $$ (-5000 / 100000) \times 100 $$
              </li>
              <li>
                <strong>Resultado:</strong> -5% de rentabilidad. El negocio está perdiendo
                dinero a pesar de vender mucho.
              </li>
            </ul>
          </div>
        </div>
      </div>

      <h2 class="text-2xl font-bold text-slate-800 mb-4">
        Consejos para optimizar tu Rentabilidad
      </h2>
      <ul class="list-disc pl-6 mb-12 space-y-4">
        <li>
          <strong>Fomenta la recurrencia:</strong> Es mucho más rentable venderle
          por segunda vez a un cliente existente que adquirir uno nuevo.
        </li>
        <li>
          <strong>Optimiza la logística:</strong> Pequeños ahorros en el embalaje
          pueden sumar miles de dólares al final del año.
        </li>
        <li>
          <strong>Sube los precios:</strong> A menudo, un incremento del 5% en el
          precio de venta tiene un impacto del 50% en el beneficio neto.
        </li>
      </ul>

      <footer
        class="bg-slate-900 text-white p-12 rounded-[3rem] text-center italic mt-12 shadow-2xl"
      >
        <p class="text-cyan-400 font-bold mb-2">Reflexión Final:</p>
        <p class="text-sm text-slate-400">
          "Vender es fácil si estás dispuesto a perder dinero. Rentabilizar es
          lo que realmente te convierte en un empresario de ecommerce."
        </p>
      </footer>
    </article>
  </main>

  <script>
    const setupEco = () => {
      const v = document.getElementById("ecoVentas") as HTMLInputElement;
      const c = document.getElementById("ecoCogs") as HTMLInputElement;
      const m = document.getElementById("ecoMarketing") as HTMLInputElement;
      const o = document.getElementById("ecoOpEx") as HTMLInputElement;
      const btn = document.getElementById("btnEcoCalc");

      const resBox = document.getElementById("ecoResultBox");
      const resRent = document.getElementById("resEcoRent");
      const resProfit = document.getElementById("resEcoProfit");
      const resPer = document.getElementById("resEcoCostPer");

      btn?.addEventListener("click", () => {
        const ventas = parseFloat(v.value) || 0;
        const cogs = parseFloat(c.value) || 0;
        const marketing = parseFloat(m.value) || 0;
        const opex = parseFloat(o.value) || 0;

        if (ventas <= 0) {
          alert("Ingresa una facturación válida.");
          return;
        }

        const profit = ventas - (cogs + marketing + opex);
        const rent = (profit / ventas) * 100;
        const mktPer = (marketing / ventas) * 100;

        if (resRent) resRent.innerText = rent.toFixed(2) + "%";
        if (resProfit)
          resProfit.innerText =
            "$" + profit.toLocaleString("es-AR", { minimumFractionDigits: 2 });
        if (resPer) resPer.innerText = mktPer.toFixed(1) + "%";

        resBox?.classList.remove("hidden");
      });
    };
    setupEco();
  </script>
</Layout>
