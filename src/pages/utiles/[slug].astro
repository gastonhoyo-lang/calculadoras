---
export const prerender = false; // Importante para que corra en el Worker
const { slug } = Astro.params;

const runtime = Astro.locals.runtime;

// Verificamos el Binding (según tu captura image_d067a0)
if (!runtime?.env?.CALCULADORAS) {
  return new Response("Error: KV 'CALCULADORAS' no vinculado.", {
    status: 500,
  });
}

const { CALCULADORAS } = runtime.env;

// Limpiamos el slug por si llega con basura o barras
const cleanSlug = slug?.toString().replace(/\/$/, "").toLowerCase();

const rawData = await CALCULADORAS.get(cleanSlug);

if (!rawData) {
  // Si no existe en el KV, enviamos un 404 informativo
  return new Response(
    `No encontrado: La llave [${cleanSlug}] no existe en el KV.`,
    { status: 404 },
  );
}

const info = JSON.parse(rawData);
---

<h1>{info.titulo}</h1>
<p>Resultado: {info.resultado}</p>

<html>
  <head>
    <title>{info.titulo}</title>
  </head>
  <body>
    <h1>{info.titulo}</h1>
  </body>
</html>
