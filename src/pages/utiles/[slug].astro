---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";

let { slug } = Astro.params;

// 1. Limpieza agresiva del slug
if (slug) {
  slug = slug.replace(/^\/+|\/+$/g, "").toLowerCase();
}

const runtime = Astro.locals.runtime;

// 2. VERIFICACIÓN CRÍTICA DEL BINDING
if (!runtime || !runtime.env || !runtime.env.CALCULADORAS) {
  // Si entra aquí, es que Cloudflare no está pasando el KV al código
  return new Response(
    `Error de Configuración: El binding "CALCULADORAS" no está conectado. 
     Asegúrate de haberlo agregado en el panel de Cloudflare (Settings -> Functions -> KV namespace bindings) 
     Y de haber hecho un nuevo Deploy.`,
    { status: 500 },
  );
}

const { CALCULADORAS } = runtime.env;
const rawData = await CALCULADORAS.get(slug);

// 3. VERIFICACIÓN DE LA LLAVE
if (!rawData) {
  // Si entra aquí, el KV funciona pero no existe esa palabra exacta
  return new Response(
    `404 - No se encontró la llave: "${slug}". 
     Verifica en tu panel de KV que la Key sea exactamente igual a esta (sin espacios ni barras).`,
    { status: 404 },
  );
}

const info = JSON.parse(rawData);

// Variables auxiliares para evitar errores de undefined
const displayTitle = info.titulo || "Calculadora";
const seoTitle = info.seo_titulo || displayTitle;
const seoDescription = info.seo_descripcion || "";
const jsonLd = info.json_ld || {};
---

<Layout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div
    id="calc-metadata"
    data-valor={info.valor}
    data-tipo={info.tipo}
    data-origen={info.unidad_origen || info.orig}
    data-destino={info.unidad_destino || info.dest}
    class="hidden"
  >
  </div>

  <section
    class="py-12 px-4 bg-gradient-to-b from-blue-50 to-slate-50 min-h-[80vh]"
  >
    <div class="max-w-3xl mx-auto">
      <nav
        class="flex mb-8 text-sm font-medium text-slate-500"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:text-blue-600 transition">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/utiles" class="hover:text-blue-600 transition">Herramientas</a
        >
        <span class="mx-2">/</span>
        <span class="text-slate-900 truncate">{displayTitle}</span>
      </nav>

      <div
        class="bg-white rounded-3xl shadow-2xl shadow-blue-900/5 border border-slate-100 overflow-hidden"
      >
        <div class="p-8 sm:p-12">
          <header class="mb-10 text-center">
            <span
              class="inline-block px-4 py-1.5 mb-4 text-xs font-bold tracking-widest text-blue-600 uppercase bg-blue-50 rounded-full"
            >
              {info.tipo === "unidades" ? "Conversor" : "Finanzas"}
            </span>
            <h1
              class="text-3xl sm:text-4xl font-black text-slate-900 leading-tight"
            >
              {displayTitle}
            </h1>
          </header>

          <div class="grid gap-6">
            <div
              class="mb-4 p-8 bg-blue-600 rounded-2xl text-center text-white shadow-lg"
            >
              <p
                class="text-xs font-bold uppercase tracking-widest mb-1 opacity-80"
              >
                Resultado Base:
              </p>
              <div class="text-4xl sm:text-5xl font-black">
                {info.resultado}
                <span class="text-xl opacity-70 font-normal"
                  >{info.dest || info.unidad_destino}</span
                >
              </div>
            </div>

            <div class="relative">
              <label
                for="input-main"
                class="block text-sm font-bold text-slate-700 mb-2 ml-1"
              >
                Ingresá el valor a {
                  info.tipo === "unidades" ? "convertir" : "calcular"
                }
              </label>
              <input
                type="number"
                id="input-main"
                placeholder={info.n ? info.n.toString() : "0.00"}
                class="w-full p-6 bg-slate-50 border-2 border-slate-100 rounded-2xl text-3xl font-bold text-slate-900 focus:border-blue-500 focus:bg-white outline-none transition-all placeholder:text-slate-300"
              />
            </div>

            <div class="flex justify-center">
              <div
                class="bg-blue-600 p-3 rounded-full shadow-lg shadow-blue-200"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-6 h-6 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                </svg>
              </div>
            </div>

            <div
              class="relative p-8 bg-white border border-slate-100 rounded-2xl text-center"
            >
              <p
                class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-2"
              >
                Nuevo Resultado
              </p>
              <div
                id="resultado-texto"
                class="text-4xl sm:text-5xl font-black text-blue-600 italic"
              >
                --
              </div>
              <p id="sub-texto" class="mt-2 text-slate-400 font-medium">
                Esperando datos...
              </p>
            </div>
          </div>
        </div>

        <div class="bg-slate-50 border-t border-slate-100 p-8">
          <h3 class="font-bold text-slate-900 mb-2">¿Cómo se calcula?</h3>
          <p class="text-slate-600 leading-relaxed text-sm">
            {info.faq_respuesta}
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const meta = document.getElementById("calc-metadata");
    if (meta) {
      const factor = parseFloat(meta.dataset.valor || "0");
      const tipo = meta.dataset.tipo;
      const destino = meta.dataset.destino || "";
      const input = document.getElementById("input-main") as HTMLInputElement;
      const display = document.getElementById("resultado-texto");
      const subTexto = document.getElementById("sub-texto");

      if (input && display && subTexto) {
        input.addEventListener("input", () => {
          const v = parseFloat(input.value);
          if (isNaN(v)) {
            display.innerText = "--";
            subTexto.innerText = "Esperando datos...";
            return;
          }
          if (tipo === "unidades") {
            const final = v * factor;
            display.innerText = `${final.toLocaleString(undefined, { maximumFractionDigits: 4 })} ${destino}`;
          } else {
            const ahorro = (v * factor) / 100;
            display.innerText = `$${(v - ahorro).toLocaleString()}`;
          }
        });
      }
    }
  </script>
</Layout>
