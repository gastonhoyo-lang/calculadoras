---
import Layout from "../../layouts/Layout.astro";
import unidades from "../../data/unidades.json";

export async function getStaticPaths() {
  console.log(`🚀 Intentando generar ${unidades.length} páginas...`);
  return unidades.map((u) => ({
    params: { slug: u.slug },
    props: { info: u },
  }));
}

const { info } = Astro.props;

// JSON-LD para Google (SEO de Élite)
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Question",
  name: info.titulo,
  acceptedAnswer: {
    "@type": "Answer",
    text: info.faq_respuesta,
  },
};
---

<Layout title={info.titulo} description={info.faq_respuesta}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="max-w-4xl mx-auto py-12 px-4">
    <div
      class="mb-10 p-8 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-[2rem] text-white shadow-2xl"
    >
      <h1 class="text-4xl font-black mb-4">{info.h1}</h1>
      <div
        class="flex items-center gap-4 bg-white/10 p-6 rounded-2xl backdrop-blur-sm"
      >
        <input
          type="number"
          id="input1"
          value={info.unidad_origen.split(" ")[0]}
          class="w-1/2 bg-white text-slate-900 p-4 rounded-xl font-bold text-2xl outline-none"
        />
        <span class="text-3xl">➔</span>
        <input
          type="number"
          id="input2"
          readonly
          class="w-1/2 bg-transparent text-white p-4 rounded-xl font-bold text-2xl border-2 border-white/20"
        />
      </div>
    </div>

    <section
      class="prose prose-lg max-w-none bg-white p-10 rounded-[2rem] border border-slate-100 shadow-sm"
    >
      <h2>Preguntas Frecuentes sobre {info.h1}</h2>
      <div class="bg-slate-50 p-6 rounded-2xl border-l-4 border-blue-500">
        <p class="font-bold text-slate-900 mb-2">{info.faq_pregunta}</p>
        <p class="text-slate-600">{info.faq_respuesta}</p>
      </div>

      <h3 class="mt-8">Uso en {info.contexto}</h3>
      <p>
        Esta conversión es vital en el sector de la {info.contexto}. Mantener la
        precisión evita errores de cálculo en proyectos profesionales y
        domésticos.
      </p>
    </section>
  </main>

  <script is:inline define:vars={{ factor: info.valor }}>
    const i1 = document.getElementById("input1");
    const i2 = document.getElementById("input2");

    const calc = () => {
      i2.value = (parseFloat(i1.value) * factor).toFixed(4);
    };
    i1.addEventListener("input", calc);
    calc(); // Cálculo inicial al cargar
  </script>
</Layout>
