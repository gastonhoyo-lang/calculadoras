---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
// Definimos las fórmulas como constantes para evitar conflictos con el compilador de Astro
const fDensidad = "(Nk / Tw) * 100";
const fEntropia = "H = -Σ P(xi) log2 P(xi)";
---

<Layout
  title="Contador de Letras y Palabras Online | Análisis de Texto SEO"
  description="Cuenta letras, palabras, caracteres y párrafos en tiempo real. Herramienta gratuita con análisis de densidad de palabras clave y tiempo de lectura."
>
  <main class="max-w-5xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1
        class="text-4xl md:text-6xl font-black text-slate-900 mb-4 tracking-tight"
      >
        Contador de <span class="text-indigo-600">Letras y Palabras</span> ✍️
      </h1>
      <p
        class="text-slate-500 text-lg font-medium max-w-2xl mx-auto text-balance"
      >
        Analiza tu contenido con precisión quirúrgica. Ideal para redactores y
        expertos en SEO.
      </p>
    </header>

    <section
      class="bg-white p-6 md:p-10 rounded-[2.5rem] border border-slate-100 shadow-2xl max-w-4xl mx-auto mb-20"
    >
      <div class="space-y-6">
        <textarea
          id="textInputMain"
          rows="10"
          placeholder="Pega tu texto aquí para analizarlo..."
          class="w-full p-6 bg-slate-50 rounded-3xl border-2 border-transparent focus:border-indigo-500 font-normal text-lg outline-none transition-all shadow-inner resize-y"
        ></textarea>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div
            class="bg-indigo-50 p-4 rounded-2xl border border-indigo-100 text-center"
          >
            <span
              class="block text-[10px] font-bold text-indigo-400 uppercase mb-1"
              >Palabras</span
            >
            <div id="countWords" class="text-2xl font-black text-slate-900">
              0
            </div>
          </div>
          <div
            class="bg-indigo-50 p-4 rounded-2xl border border-indigo-100 text-center"
          >
            <span
              class="block text-[10px] font-bold text-indigo-400 uppercase mb-1"
              >Caracteres</span
            >
            <div id="countChars" class="text-2xl font-black text-slate-900">
              0
            </div>
          </div>
          <div
            class="bg-indigo-50 p-4 rounded-2xl border border-indigo-100 text-center"
          >
            <span
              class="block text-[10px] font-bold text-indigo-400 uppercase mb-1"
              >Sin Espacios</span
            >
            <div id="countNoSpaces" class="text-2xl font-black text-slate-900">
              0
            </div>
          </div>
          <div
            class="bg-indigo-50 p-4 rounded-2xl border border-indigo-100 text-center"
          >
            <span
              class="block text-[10px] font-bold text-indigo-400 uppercase mb-1"
              >Párrafos</span
            >
            <div
              id="countParagraphs"
              class="text-2xl font-black text-slate-900"
            >
              0
            </div>
          </div>
        </div>

        <div
          class="flex flex-wrap gap-4 justify-between items-center bg-slate-900 p-4 rounded-2xl text-white"
        >
          <div class="text-sm">
            <span class="text-indigo-400 font-bold italic"
              >Tiempo de lectura est.:</span
            >
            <span id="readingTime" class="ml-2 font-mono">0 min</span>
          </div>
          <button
            id="clearBtnMain"
            class="text-xs uppercase font-black hover:text-red-400 transition-colors"
            >Limpiar</button
          >
        </div>
      </div>
    </section>

    <article
      class="prose prose-slate max-w-none border-t border-slate-200 pt-16 text-slate-700 font-light leading-relaxed"
    >
      <h2 class="text-3xl font-black text-slate-900 mb-6 italic">
        Importancia del Contador en la Redacción Profesional
      </h2>

      <p class="mb-6">
        Conocer la extensión exacta de un escrito es fundamental para el <strong
          >SEO técnico</strong
        >. Google suele truncar los títulos de página después de los 60
        caracteres y las descripciones tras los 155-160. Nuestra herramienta te
        ayuda a mantenerte dentro de esos márgenes críticos para mejorar el CTR.
      </p>

      <h3 class="text-2xl font-bold text-slate-800 mb-4 text-balance">
        Métricas de Densidad y Legibilidad
      </h3>
      <p class="mb-4">
        Para analistas avanzados, la densidad de palabras clave se calcula
        mediante:
      </p>

      <div class="bg-slate-50 p-6 rounded-2xl mb-8 font-mono text-center">
        $$ {fDensidad} $$
      </div>

      <p class="mb-6">
        Esta fórmula permite identificar si estamos cayendo en el <em
          >keyword stuffing</em
        >, una práctica penalizada por buscadores. Además, el tiempo de lectura
        estimado ayuda a mejorar la experiencia del usuario (UX) al informar
        cuánto tardará en consumir el contenido.
      </p>

      <h3 class="text-2xl font-bold text-slate-800 mb-4">
        Ejemplos Prácticos de Aplicación
      </h3>

      <div class="space-y-6 mb-12">
        <div class="p-6 bg-indigo-50 rounded-3xl border border-indigo-100">
          <p class="font-bold mb-2">Caso 1: Redes Sociales</p>
          <p class="text-sm">
            Si redactas un hilo para X (Twitter), cada bloque debe ser menor a
            280 caracteres. Esta herramienta te permite fragmentar tu contenido
            de forma eficiente.
          </p>
        </div>
        <div class="p-6 bg-indigo-50 rounded-3xl border border-indigo-100">
          <p class="font-bold mb-2">Caso 2: Redacción de Blogs</p>
          <p class="text-sm">
            Un post educativo ideal debería tener entre 800 y 1200 palabras para
            posicionar en la primera página de Google para términos
            competitivos.
          </p>
        </div>
      </div>

      <p class="mb-6">
        Por último, la entropía léxica ({fEntropia}) nos indica la riqueza del
        vocabulario. Un texto con alta entropía suele ser percibido como más
        profesional y variado por el lector humano y por los algoritmos de IA.
      </p>

      <footer
        class="bg-slate-900 text-white p-12 rounded-[3rem] text-center italic mt-12"
      >
        <p class="text-sm text-slate-400">
          "La precisión en el lenguaje es la base de la claridad mental."
        </p>
      </footer>
    </article>
  </main>

  <script>
    const initCounter = () => {
      const area = document.getElementById(
        "textInputMain",
      ) as HTMLTextAreaElement;
      const wordRes = document.getElementById("countWords");
      const charRes = document.getElementById("countChars");
      const spaceRes = document.getElementById("countNoSpaces");
      const paraRes = document.getElementById("countParagraphs");
      const timeRes = document.getElementById("readingTime");
      const clearBtn = document.getElementById("clearBtnMain");

      const analyze = () => {
        const val = area.value;
        const words = val
          .trim()
          .split(/\s+/)
          .filter((w) => w.length > 0);
        const chars = val.length;
        const noSpaces = val.replace(/\s+/g, "").length;
        const paragraphs = val
          .split(/\n+/)
          .filter((p) => p.trim().length > 0).length;
        const minutes = Math.ceil(words.length / 225);

        if (wordRes) wordRes.innerText = words.length.toString();
        if (charRes) charRes.innerText = chars.toString();
        if (spaceRes) spaceRes.innerText = noSpaces.toString();
        if (paraRes) paraRes.innerText = paragraphs.toString();
        if (timeRes) timeRes.innerText = `${minutes} min`;
      };

      area?.addEventListener("input", analyze);
      clearBtn?.addEventListener("click", () => {
        area.value = "";
        analyze();
      });
    };
    initCounter();
  </script>
</Layout>
