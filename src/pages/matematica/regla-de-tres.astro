---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Calculadora de Regla de Tres Simple | Directa e Inversa Online"
  description="Resolvé problemas de proporcionalidad con nuestra calculadora de regla de tres simple. Guía paso a paso para proporciones directas e inversas."
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <header class="text-center mb-12">
      <h1
        class="text-4xl md:text-6xl font-black text-slate-900 tracking-tight mb-4"
      >
        Regla de <span class="text-emerald-600">Tres Simple</span> 🧮
      </h1>
    </header>

    <div
      class="bg-white p-8 md:p-12 rounded-[3rem] border border-slate-100 shadow-sm mb-16"
    >
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
        <div class="text-center">
          <label
            class="block text-[10px] font-black text-slate-400 uppercase mb-2"
            >Valor A</label
          >
          <input
            type="number"
            id="vA"
            placeholder="Ej: 100"
            class="w-full p-5 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-emerald-500 outline-none text-center font-black text-2xl"
          />
        </div>
        <div class="hidden md:flex justify-center text-slate-300 text-3xl">
          ───
        </div>
        <div class="text-center">
          <label
            class="block text-[10px] font-black text-slate-400 uppercase mb-2"
            >Valor B</label
          >
          <input
            type="number"
            id="vB"
            placeholder="Ej: 50"
            class="w-full p-5 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-emerald-500 outline-none text-center font-black text-2xl"
          />
        </div>
        <div class="text-center">
          <label
            class="block text-[10px] font-black text-slate-400 uppercase mb-2"
            >Valor C</label
          >
          <input
            type="number"
            id="vC"
            placeholder="Ej: 200"
            class="w-full p-5 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-emerald-500 outline-none text-center font-black text-2xl"
          />
        </div>
        <div class="hidden md:flex justify-center text-slate-300 text-3xl">
          ───
        </div>
        <div
          class="w-full bg-slate-900 p-5 rounded-[2rem] text-center border-4 border-emerald-500/20"
        >
          <p class="text-emerald-400 text-[10px] font-black uppercase mb-1">
            Resultado (X)
          </p>
          <div id="resFinal" class="text-white text-4xl font-black font-mono">
            ?
          </div>
        </div>
      </div>

      <div class="flex flex-col md:flex-row gap-4 mt-12 justify-center">
        <button
          id="calcDir"
          class="bg-emerald-600 text-white px-10 py-5 rounded-2xl font-bold hover:bg-emerald-700 transition-all active:scale-95"
        >
          Calcular Directa
        </button>
        <button
          id="calcInv"
          class="bg-slate-800 text-white px-10 py-5 rounded-2xl font-bold hover:bg-slate-950 transition-all active:scale-95"
        >
          Calcular Inversa
        </button>
      </div>
    </div>

    <article
      class="prose prose-slate max-w-none border-t border-slate-200 pt-16 pb-20 text-slate-600"
    >
      <h2
        class="text-3xl font-black text-slate-800 mb-6 text-center text-balance"
      >
        Cómo funciona la Regla de Tres
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-slate-50 p-6 rounded-2xl">
          <h3 class="font-bold mb-2">Proporción Directa</h3>
          <p class="text-sm">
            Si una variable sube, la otra también. Ejemplo: Más cantidad de
            productos, más costo total.
          </p>
          <p class="mt-4 font-mono font-bold text-emerald-600 text-center">
            $$X = (C \cdot B) / A$$
          </p>
        </div>
        <div class="bg-slate-50 p-6 rounded-2xl">
          <h3 class="font-bold mb-2">Proporción Inversa</h3>
          <p class="text-sm">
            Si una variable sube, la otra baja. Ejemplo: Más velocidad, menos
            tiempo de viaje.
          </p>
          <p class="mt-4 font-mono font-bold text-slate-700 text-center">
            $$X = (A \cdot B) / C$$
          </p>
        </div>
      </div>
    </article>
  </div>

  <script is:inline>
    // Usamos is:inline para que Astro no procese el JS y evitemos errores de compilación de tipos
    const btnDir = document.getElementById("calcDir");
    const btnInv = document.getElementById("calcInv");
    const resBox = document.getElementById("resFinal");

    function solve(type) {
      const a = parseFloat(document.getElementById("vA").value);
      const b = parseFloat(document.getElementById("vB").value);
      const c = parseFloat(document.getElementById("vC").value);

      if (isNaN(a) || isNaN(b) || isNaN(c)) {
        alert("Completá todos los campos");
        return;
      }

      let result = 0;
      if (type === "directa") {
        if (a === 0) return alert("A no puede ser 0");
        result = (c * b) / a;
      } else {
        if (c === 0) return alert("C no puede ser 0");
        result = (a * b) / c;
      }

      resBox.innerText = Number.isInteger(result) ? result : result.toFixed(2);
    }

    btnDir.addEventListener("click", () => solve("directa"));
    btnInv.addEventListener("click", () => solve("inversa"));
  </script>
</Layout>
