---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Calculadora de Área de Triángulo | Fórmulas y Cálculo Online"
  description="Calculá la superficie o área de cualquier triángulo ingresando la base y la altura. Herramienta rápida, gratuita y educativa."
>
  <div class="max-w-4xl mx-auto px-4">
    <header class="text-center mb-12">
      <h1
        class="text-4xl md:text-6xl font-black text-slate-900 tracking-tight mb-4"
      >
        Área de un <span class="text-orange-500">Triángulo</span>
      </h1>
      <p class="text-slate-500 text-lg font-medium max-w-xl mx-auto">
        Obtené la superficie de forma instantánea con la fórmula de base por
        altura.
      </p>
    </header>

    <div class="grid lg:grid-cols-2 gap-8 items-center mb-16">
      <div
        class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm space-y-6"
      >
        <div>
          <label
            class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-3"
            >Base (b)</label
          >
          <input
            type="number"
            id="baseT"
            placeholder="Ej: 10"
            class="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-orange-500 rounded-2xl outline-none transition-all font-bold text-xl text-slate-700"
          />
        </div>

        <div>
          <label
            class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-3"
            >Altura (h)</label
          >
          <input
            type="number"
            id="alturaT"
            placeholder="Ej: 15"
            class="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-orange-500 rounded-2xl outline-none transition-all font-bold text-xl text-slate-700"
          />
        </div>

        <button
          id="btnTriangulo"
          class="w-full bg-orange-500 text-white p-5 rounded-2xl font-bold hover:bg-orange-600 transition-all shadow-lg shadow-orange-100"
        >
          Calcular Área
        </button>
      </div>

      <div
        id="resTriContainer"
        class="hidden animate-in fade-in zoom-in duration-500"
      >
        <div
          class="bg-slate-900 text-white p-10 rounded-[2.5rem] text-center shadow-xl"
        >
          <p
            class="text-orange-400 text-sm font-bold uppercase tracking-widest mb-2"
          >
            El área resultante es
          </p>
          <h2 id="areaTVal" class="text-6xl font-black text-white mb-2"></h2>
          <p class="text-slate-400 text-sm">unidades cuadradas</p>
        </div>
      </div>
    </div>

    <article
      class="prose prose-slate max-w-none border-t border-slate-200 pt-16 pb-20 text-slate-600"
    >
      <h2 class="text-3xl font-black text-slate-800 mb-6">
        ¿Cómo se calcula el área de un triángulo?
      </h2>
      <p>
        Para hallar la superficie de un triángulo, sin importar si es isósceles,
        equilátero o escaleno, la fórmula matemática universal es:
      </p>

      <div
        class="bg-orange-50 p-8 rounded-3xl text-center my-8 border border-orange-100"
      >
        <p class="text-2xl font-mono font-bold text-orange-700">
          Área = (Base × Altura) / 2
        </p>
      </div>

      <h3 class="text-2xl font-bold text-slate-800 mb-4">
        Ejemplo paso a paso:
      </h3>
    </article>
  </div></Layout
>
