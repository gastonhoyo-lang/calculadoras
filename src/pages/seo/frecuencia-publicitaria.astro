---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Calculadora de Frecuencia Publicitaria | Optimización de Fatiga"
  description="Calculá cuántas veces ven tus anuncios los usuarios. Evitá la fatiga publicitaria y optimizá el impacto de tus campañas de marketing."
>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-black text-slate-900 mb-4 tracking-tight">
        Frecuencia Publicitaria
      </h1>
      <p class="text-slate-600 max-w-2xl mx-auto italic">
        "Impacto justo, sin saturación."
      </p>
    </div>

    <div
      class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100 mb-12"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        <div class="space-y-4">
          <div>
            <label
              class="block text-xs font-bold uppercase text-slate-400 mb-2 ml-1"
              >Impresiones Totales</label
            >
            <input
              type="number"
              id="impressions"
              class="w-full p-4 bg-slate-50 rounded-2xl border-none focus:ring-2 focus:ring-lime-500 outline-none transition-all font-mono"
              placeholder="Ej: 20000"
            />
          </div>
          <div>
            <label
              class="block text-xs font-bold uppercase text-slate-400 mb-2 ml-1"
              >Alcance Único (Personas)</label
            >
            <input
              type="number"
              id="reach"
              class="w-full p-4 bg-slate-50 rounded-2xl border-none focus:ring-2 focus:ring-lime-500 outline-none transition-all font-mono"
              placeholder="Ej: 5000"
            />
          </div>
        </div>

        <div class="flex items-center justify-center">
          <div
            class="text-center p-8 bg-lime-50 rounded-[2rem] border border-lime-100 w-full"
          >
            <span
              class="block text-[10px] font-bold uppercase text-lime-400 mb-2"
              >Frecuencia Promedio</span
            >
            <div id="freqResult" class="text-6xl font-black text-lime-700">
              0.0
            </div>
            <div
              id="freqStatus"
              class="mt-4 inline-block px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white text-lime-400"
            >
              Esperando datos
            </div>
          </div>
        </div>
      </div>
    </div>

    <section
      class="prose prose-slate max-w-none border-t border-slate-100 pt-12 text-slate-700"
    >
      <h2 class="text-3xl font-black text-slate-900 mb-6">
        ¿Qué es la Frecuencia y por qué importa?
      </h2>
      <p>
        La frecuencia es el número promedio de veces que una persona única ve tu
        contenido. Es una métrica de equilibrio: una frecuencia muy baja puede
        no ser suficiente para que el usuario recuerde tu marca, pero una
        frecuencia muy alta agota el presupuesto y molesta al público.
      </p>

      <h3 class="text-xl font-bold text-slate-800 mt-8">
        Ejemplo Extenso de Fatiga de Anuncio:
      </h3>
      <div class="bg-lime-50 p-6 rounded-2xl border-l-4 border-lime-500 my-6">
        <p class="text-sm mb-4">
          Si tu campaña tiene 50,000 impresiones y un alcance de 10,000
          personas, tu <strong>frecuencia es de 5.0</strong>.
        </p>
        <p class="text-sm">
          <strong>Interpretación:</strong> Cada persona ha visto tu anuncio 5 veces
          en promedio. Si después de la tercera vez no hicieron clic, es muy probable
          que no lo hagan nunca. En este punto, tu [CTR](/seo/calculadora-ctr) empezará
          a bajar drásticamente y tu [CPC](/seo/calculadora-cpc) subirá.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        <div class="p-6 bg-slate-50 rounded-2xl border border-slate-200">
          <h4 class="font-bold text-slate-900 mb-2">Frecuencia Óptima</h4>
          <p class="text-xs leading-relaxed">
            Para campañas de branding, se suele buscar una frecuencia de 3 a 5.
            Para campañas de retargeting, puede ser un poco más alta, pero
            siempre monitoreando que el costo por conversión no se dispare.
          </p>
        </div>
        <div class="p-6 bg-slate-50 rounded-2xl border border-slate-200">
          <h4 class="font-bold text-slate-900 mb-2">Rotación de Creativos</h4>
          <p class="text-xs leading-relaxed">
            Cuando detectes una frecuencia mayor a 6, es el momento ideal para
            cambiar el diseño o el texto. Usá nuestro [Contador de Caracteres
            SEO](/seo/contador-caracteres) para redactar nuevos copies
            impactantes rápidamente.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const impIn = document.getElementById("impressions") as HTMLInputElement;
  const reachIn = document.getElementById("reach") as HTMLInputElement;
  const resOut = document.getElementById("freqResult");
  const statusOut = document.getElementById("freqStatus");

  const updateFreq = () => {
    const imp = parseFloat(impIn.value);
    const reach = parseFloat(reachIn.value);

    if (reach > 0 && imp >= 0) {
      const freq = imp / reach;
      if (resOut) resOut.innerText = freq.toFixed(1);

      if (statusOut) {
        if (freq < 1.5) {
          statusOut.innerText = "Alcance nuevo - Explorando";
          statusOut.className =
            "mt-4 inline-block px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-blue-100 text-blue-600";
        } else if (freq <= 4) {
          statusOut.innerText = "Frecuencia Saludable";
          statusOut.className =
            "mt-4 inline-block px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-emerald-100 text-emerald-600";
        } else {
          statusOut.innerText = "¡Alerta! Fatiga publicitaria";
          statusOut.className =
            "mt-4 inline-block px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-red-100 text-red-600";
        }
      }
    } else {
      if (resOut) resOut.innerText = "0.0";
    }
  };

  impIn?.addEventListener("input", updateFreq);
  reachIn?.addEventListener("input", updateFreq);
</script>
