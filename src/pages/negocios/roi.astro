---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Calculadora de ROI | Retorno de Inversión"
  description="Calculá la rentabilidad de tus proyectos o inversiones de forma simple y rápida."
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <header class="text-center mb-12">
      <h1
        class="text-4xl md:text-6xl font-black text-slate-900 tracking-tight mb-4"
      >
        Calculadora de <span class="text-blue-600">ROI</span> 📈
      </h1>
    </header>

    <div
      class="bg-white p-8 md:p-12 rounded-[3rem] border border-slate-100 shadow-sm max-w-lg mx-auto mb-16"
    >
      <div class="space-y-6">
        <div>
          <label
            class="block text-[10px] font-black text-slate-400 uppercase mb-2 text-center"
            >Inversión ($)</label
          >
          <input
            type="number"
            id="i"
            placeholder="0"
            class="w-full p-5 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-blue-500 outline-none text-center font-black text-2xl"
          />
        </div>
        <div>
          <label
            class="block text-[10px] font-black text-slate-400 uppercase mb-2 text-center"
            >Retorno ($)</label
          >
          <input
            type="number"
            id="r"
            placeholder="0"
            class="w-full p-5 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-blue-500 outline-none text-center font-black text-2xl"
          />
        </div>
        <button
          id="b"
          class="w-full bg-blue-600 text-white p-5 rounded-2xl font-black hover:bg-blue-700 active:scale-95"
        >
          Calcular
        </button>
      </div>

      <div
        id="res"
        class="hidden mt-10 p-8 bg-blue-50 rounded-[2.5rem] text-center"
      >
        <div id="v" class="text-5xl font-black text-slate-900">0%</div>
      </div>
    </div>

    <article
      class="prose prose-slate max-w-none border-t border-slate-200 pt-16 text-slate-600"
    >
      <h2 class="text-2xl font-black text-slate-800">¿Qué es el ROI?</h2>
      <p>
        El ROI mide cuánto ganaste o perdiste en relación al dinero invertido.
      </p>

      <div class="bg-slate-50 p-6 rounded-2xl font-mono text-center my-6">
        <p class="text-sm font-bold">Fórmula:</p>
        <p class="text-lg">ROI = [(Beneficio - Inversión) / Inversión] x 100</p>
      </div>
    </article>
  </div>

  <script is:inline>
    // Script blindado
    (function () {
      const btn = document.getElementById("b");
      if (btn) {
        btn.addEventListener("click", function () {
          const inv = parseFloat(document.getElementById("i").value);
          const ret = parseFloat(document.getElementById("r").value);
          const valDisplay = document.getElementById("v");
          const resBox = document.getElementById("res");

          if (inv > 0 && !isNaN(ret)) {
            const resultado = ((ret - inv) / inv) * 100;
            if (valDisplay) valDisplay.innerText = resultado.toFixed(2) + "%";
            if (resBox) resBox.classList.remove("hidden");
          } else {
            alert("Ingresá valores válidos (Inversión mayor a 0)");
          }
        });
      }
    })();
  </script>
</Layout>
