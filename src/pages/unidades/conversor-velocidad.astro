---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
// Reparación de Build: Eliminación total de llaves {} en el HTML.
// Las fórmulas se presentan en texto plano dentro de contenedores seguros.
---

<Layout
  title="Conversor de Velocidad | km/h, m/s, mph y nudos"
  description="Calculadora profesional de conversión de velocidad. Convierte entre kilómetros por hora, metros por segundo y millas por hora."
>
  <main class="max-w-5xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1
        class="text-4xl md:text-6xl font-black text-slate-900 mb-4 tracking-tight"
      >
        Conversor de <span class="text-emerald-600">Velocidad</span> 🚀
      </h1>
      <p
        class="text-slate-500 text-lg font-medium max-w-2xl mx-auto text-balance"
      >
        Transforma unidades de rapidez de forma instantánea. Precisión exacta
        para ingeniería y física.
      </p>
    </header>

    <section
      class="bg-white p-8 md:p-12 rounded-[3rem] border border-slate-100 shadow-2xl max-w-3xl mx-auto mb-20"
    >
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label
            for="speedInp"
            class="block text-xs font-bold text-slate-400 uppercase ml-2 tracking-widest mb-2"
          >
            Magnitud de Velocidad
          </label>
          <input
            type="number"
            id="speedInp"
            placeholder="Ej: 120"
            step="any"
            class="w-full p-5 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-emerald-500 font-bold text-xl outline-none transition-all shadow-sm"
          />
        </div>
        <div>
          <label
            for="speedFrom"
            class="block text-xs font-bold text-slate-400 uppercase ml-2 tracking-widest mb-2"
          >
            Unidad de Origen
          </label>
          <select
            id="speedFrom"
            class="w-full p-5 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-emerald-500 font-bold text-lg outline-none transition-all shadow-sm cursor-pointer"
          >
            <option value="kmh">Km/h (Kilómetros por hora)</option>
            <option value="ms">m/s (Metros por segundo)</option>
            <option value="mph">mph (Millas por hora)</option>
            <option value="knots">Nudos (Knots)</option>
          </select>
        </div>
      </div>

      <button
        id="btnConvert"
        class="w-full mt-6 bg-slate-900 text-white p-5 rounded-2xl font-bold hover:bg-emerald-600 transition-all shadow-lg active:scale-95 text-lg"
      >
        Convertir Ahora
      </button>

      <div
        id="resBox"
        class="hidden mt-10 p-8 bg-emerald-50 rounded-[2.5rem] border-2 border-emerald-100 animate-in fade-in zoom-in duration-500"
      >
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
          <div
            class="p-4 bg-white rounded-2xl shadow-sm border border-emerald-100"
          >
            <p class="text-emerald-600 text-[10px] font-bold uppercase mb-1">
              km/h
            </p>
            <div id="vKmh" class="text-xl font-black text-slate-900 font-mono">
            </div>
          </div>
          <div
            class="p-4 bg-white rounded-2xl shadow-sm border border-emerald-100"
          >
            <p class="text-emerald-600 text-[10px] font-bold uppercase mb-1">
              m/s
            </p>
            <div id="vMs" class="text-xl font-black text-slate-900 font-mono">
            </div>
          </div>
          <div
            class="p-4 bg-white rounded-2xl shadow-sm border border-emerald-100"
          >
            <p class="text-emerald-600 text-[10px] font-bold uppercase mb-1">
              mph
            </p>
            <div id="vMph" class="text-xl font-black text-slate-900 font-mono">
            </div>
          </div>
          <div
            class="p-4 bg-white rounded-2xl shadow-sm border border-emerald-100"
          >
            <p class="text-emerald-600 text-[10px] font-bold uppercase mb-1">
              Nudos
            </p>
            <div
              id="vKnots"
              class="text-xl font-black text-slate-900 font-mono"
            >
            </div>
          </div>
        </div>
      </div>
    </section>

    <article
      class="prose prose-slate max-w-none border-t border-slate-200 pt-16 text-slate-700 font-light"
    >
      <section class="mb-16">
        <h2 class="text-3xl font-black text-slate-900 mb-6 italic">
          La Importancia de la Conversión de Velocidad
        </h2>
        <p class="text-lg leading-relaxed mb-6">
          La velocidad define qué tan rápido un objeto cambia de posición. En la
          ingeniería moderna, la capacidad de traducir estas magnitudes entre
          diferentes sistemas es vital. Por ejemplo, la aviación utiliza nudos,
          mientras que los límites de velocidad terrestres varían entre km/h y
          mph según el país.
        </p>
      </section>

      <section class="mb-16">
        <h2 class="text-3xl font-black text-slate-900 mb-6 italic text-center">
          Fórmulas de Conversión Maestras
        </h2>
        <p class="mb-8 text-center text-lg italic">
          Utiliza estos factores de conversión para obtener resultados precisos:
        </p>

        <div class="grid md:grid-cols-2 gap-6 mb-12">
          <div
            class="bg-slate-900 text-white p-8 rounded-[2.5rem] shadow-xl text-center"
          >
            <p
              class="text-xs font-bold text-emerald-400 mb-4 uppercase tracking-widest"
            >
              km/h a m/s
            </p>
            <div class="text-2xl font-mono">m/s = km/h / 3.6</div>
          </div>
          <div
            class="bg-slate-900 text-white p-8 rounded-[2.5rem] shadow-xl text-center"
          >
            <p
              class="text-xs font-bold text-emerald-400 mb-4 uppercase tracking-widest"
            >
              mph a km/h
            </p>
            <div class="text-2xl font-mono">km/h = mph * 1.60934</div>
          </div>
        </div>
      </section>

      <section class="mb-16">
        <h2 class="text-3xl font-black text-slate-900 mb-6 italic">
          Ejemplos Prácticos
        </h2>
        <div class="space-y-6">
          <div
            class="bg-emerald-50 p-8 rounded-[2.5rem] border border-emerald-100"
          >
            <h4 class="font-black text-emerald-900 mb-2">
              1. Velocidad de un Avión
            </h4>
            <p class="text-slate-600 leading-relaxed">
              Un avión vuela a 500 nudos. En kilómetros por hora es: 500 * 1.852
              = 926 km/h.
            </p>
          </div>
          <div
            class="bg-emerald-50 p-8 rounded-[2.5rem] border border-emerald-100"
          >
            <h4 class="font-black text-emerald-900 mb-2">
              2. El Récord de Velocidad Humana
            </h4>
            <p class="text-slate-600 leading-relaxed">
              Correr a 10 m/s equivale a 10 * 3.6 = 36 km/h.
            </p>
          </div>
        </div>
      </section>

      <footer
        class="bg-slate-900 text-white p-12 rounded-[3rem] text-center italic mt-12"
      >
        <p class="text-sm text-slate-400">
          "Medir con exactitud es el primer paso hacia la innovación."
        </p>
      </footer>
    </article>
  </main>

  <script>
    const setupS = () => {
      const i = document.getElementById("speedInp") as HTMLInputElement;
      const f = document.getElementById("speedFrom") as HTMLSelectElement;
      const b = document.getElementById("btnConvert");
      const bx = document.getElementById("resBox");

      const vK = document.getElementById("vKmh");
      const vM = document.getElementById("vMs");
      const vMp = document.getElementById("vMph");
      const vKn = document.getElementById("vKnots");

      b?.addEventListener("click", () => {
        const val = parseFloat(i.value);
        if (isNaN(val)) return alert("Ingresa un número");

        let k = 0;
        const sel = f.value;

        if (sel === "kmh") k = val;
        else if (sel === "ms") k = val * 3.6;
        else if (sel === "mph") k = val * 1.60934;
        else if (sel === "knots") k = val * 1.852;

        if (vK && vM && vMp && vKn) {
          vK.innerText = k.toFixed(2);
          vM.innerText = (k / 3.6).toFixed(2);
          vMp.innerText = (k / 1.60934).toFixed(2);
          vKn.innerText = (k / 1.852).toFixed(2);
        }

        bx?.classList.remove("hidden");
        bx?.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    };
    setupS();
  </script>
</Layout>
