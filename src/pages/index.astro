---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import { calculadoras } from "../data/calculadoras";
---

<Layout
  title="Chieffin | Calculadoras Online Gratuitas y Rápidas"
  description="Resolvé problemas de matemáticas, finanzas y negocios con nuestras calculadoras inteligentes. Simples, rápidas y precisas."
>
  <main class="max-w-6xl mx-auto px-4">
    <header class="text-center py-16 md:py-24">
      <h1
        class="text-5xl md:text-7xl font-black text-slate-900 tracking-tight mb-6"
      >
        Todas las <span class="text-blue-600">Calculadoras</span> 🧮
      </h1>
      <p
        class="text-slate-500 text-lg md:text-xl max-w-2xl mx-auto font-medium"
      >
        Herramientas gratuitas para simplificar tus cálculos diarios. Desde
        regla de tres hasta retorno de inversión.
      </p>
    </header>

    <section
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20"
      aria-label="Listado de calculadoras disponibles"
    >
      {
        calculadoras.map((calc) => (
          <Card
            title={calc.title}
            href={calc.href}
            description={calc.description}
            icon={calc.icon}
          />
        ))
      }
    </section>
  </main>
</Layout>
