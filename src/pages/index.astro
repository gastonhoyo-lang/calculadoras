---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Calculadoras Gratis y Herramientas Inteligentes">
  <div class="text-center py-16 px-4">
    <h1
      class="text-5xl md:text-6xl font-black text-slate-900 tracking-tight mb-4"
    >
      Calculadoras <span
        class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600"
        >Inteligentes</span
      >
    </h1>
    <p class="text-slate-500 text-lg max-w-2xl mx-auto font-medium">
      Simuladores de préstamos, cálculo de IVA, porcentajes e inversiones en un
      solo clic.
    </p>
  </div>

  <div class="grid md:grid-cols-3 gap-6 px-4 max-w-6xl mx-auto mb-20">
    <a
      href="/finanzas/porcentaje"
      class="group p-8 bg-white rounded-3xl border border-slate-100 shadow-sm hover:shadow-xl hover:border-blue-500 transition-all duration-300"
    >
      <div
        class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors"
      >
        <span class="font-bold text-xl">%</span>
      </div>
      <h3 class="text-xl font-bold text-slate-800 mb-2">Porcentajes</h3>
      <p class="text-slate-500 text-sm leading-relaxed">
        Calculá IVA, descuentos y variaciones de forma rápida.
      </p>
    </a>

    <a
      href="/finanzas/prestamo"
      class="group p-8 bg-white rounded-3xl border border-slate-100 shadow-sm hover:shadow-xl hover:border-indigo-500 transition-all duration-300"
    >
      <div
        class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-colors"
      >
        <span class="font-bold text-xl">$</span>
      </div>
      <h3 class="text-xl font-bold text-slate-800 mb-2">
        Simulador de Préstamos
      </h3>
      <p class="text-slate-500 text-sm leading-relaxed">
        Calculá cuotas mensuales y el costo total de tu crédito.
      </p>
    </a> href="/finanzas/iva" class="group p-8 bg-white rounded-3xl border border-slate-100
    shadow-sm hover:shadow-xl hover:border-blue-600 transition-all duration-300">
    <div
      class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors"
    >
      <span class="font-black text-xs">IVA</span>
    </div>
    <h3 class="text-xl font-bold text-slate-800 mb-2">Calculadora de IVA</h3>
    <p class="text-slate-500 text-sm leading-relaxed">
      Sumá o restá el IVA (21%, 10.5%) a cualquier monto de forma profesional.
    </p>
  </div>

  <a
    href="/finanzas/interescompuesto"
    class="group p-8 bg-white rounded-3xl border border-slate-100 shadow-sm hover:shadow-xl hover:border-emerald-500 transition-all duration-300"
  >
    <div
      class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-emerald-600 group-hover:text-white transition-colors"
    >
      <span class="font-bold text-xl">🚀</span>
    </div>
    <h3 class="text-xl font-bold text-slate-800 mb-2">Interés Compuesto</h3>
    <p class="text-slate-500 text-sm leading-relaxed">
      Proyectá tus ahorros e inversiones a largo plazo.
    </p>
  </a>
</Layout>
