---
import Layout from "../layouts/Layout.astro";
import { calculadoras } from "../data/calculadoras";
import unidades from "../data/unidades.json"; // <--- IMPORTANTE: Importamos el motor masivo

const categorias = [
  {
    id: "finanzas",
    nombre: "Finanzas y Negocios",
    icon: "💰",
    color: "bg-emerald-50 text-emerald-700",
  },
  {
    id: "negocios",
    nombre: "Negocios y Emprendedores",
    icon: "📈",
    color: "bg-indigo-50 text-indigo-700",
  },
  {
    id: "hogar",
    nombre: "Hogar y Construcción",
    icon: "🏗️",
    color: "bg-slate-100 text-slate-700",
  },
  {
    id: "salud",
    nombre: "Salud y Bienestar",
    icon: "❤️",
    color: "bg-red-50 text-red-700",
  },
  {
    id: "utiles",
    nombre: "Herramientas Útiles",
    icon: "🛠️",
    color: "bg-blue-50 text-blue-700",
  },
  {
    id: "matematica",
    nombre: "Matemática y Geometría",
    icon: "📐",
    color: "bg-orange-50 text-orange-700",
  },
  {
    id: "seo",
    nombre: "SEO y Marketing",
    icon: "🚀",
    color: "bg-purple-50 text-purple-700",
  },
  {
    id: "unidades",
    nombre: "Conversores de Medida",
    icon: "↔️",
    color: "bg-amber-50 text-amber-700",
  },
];

// 1. Obtener calculadoras manuales
const getCalcsByCat = (cat: string) =>
  calculadoras.filter((c) => c.link.includes(`/${cat}/`));

// 2. Obtener una muestra representativa de las masivas (para no saturar la Home)
// Mostramos las 6 más importantes para que Google las rastree
const unidadesDestacadas = unidades.slice(0, 6);
---

<Layout
  title="Chieffin | Herramientas y Calculadoras Gratuitas Online"
  description="Más de 60,000 calculadoras y conversores gratuitos: Finanzas, Salud, Unidades y SEO. Rápidas, precisas y sin registro."
>
  <section class="bg-white pt-20 pb-16 border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1
        class="text-6xl md:text-8xl font-black text-slate-900 tracking-tight mb-6"
      >
        Herramientas que <br /><span class="text-indigo-600">simplifican</span> tu
        vida.
      </h1>
      <p class="text-slate-500 text-xl font-medium max-w-2xl mx-auto mb-10">
        Accede a nuestra red de <span class="text-slate-900 font-bold"
          >más de 60,000</span
        > herramientas de precisión. Gratis, instantáneo y diseñado para profesionales.
      </p>

      <div class="relative max-w-2xl mx-auto">
        <input
          type="text"
          id="searchBox"
          placeholder="¿Qué necesitás calcular? (ej: millas, IVA, descuento...)"
          class="w-full p-8 pl-16 bg-slate-50 border-2 border-transparent focus:border-indigo-500 rounded-[2.5rem] shadow-xl outline-none font-bold text-xl transition-all"
        />
        <span class="absolute left-6 top-8 text-3xl text-slate-300">🔍</span>
      </div>
    </div>
  </section>

  <main class="max-w-6xl mx-auto px-4 py-20">
    {
      categorias.map((cat) => (
        <div class="mb-24 category-section" data-category={cat.id}>
          <div class="flex items-center justify-between mb-10">
            <div class="flex items-center gap-4">
              <div
                class={`${cat.color} w-14 h-14 rounded-2xl flex items-center justify-center text-3xl shadow-sm`}
              >
                {cat.icon}
              </div>
              <h2 class="text-4xl font-black text-slate-900 tracking-tight">
                {cat.nombre}
              </h2>
            </div>
            {cat.id === "unidades" && (
              <a
                href="/utiles"
                class="text-indigo-600 font-bold hover:underline"
              >
                Ver todas (60,000+) →
              </a>
            )}
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {/* RENDERIZADO DE CALCULADORAS MANUALES */}
            {getCalcsByCat(cat.id).map((calc) => (
              <a
                href={calc.link}
                class="group bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 flex flex-col h-full card-calc"
                data-keywords={(
                  calc.titulo +
                  " " +
                  (calc.description || "") +
                  " " +
                  (calc.keywords || "")
                ).toLowerCase()}
              >
                <div class="text-5xl mb-6 group-hover:rotate-12 transition-transform duration-300 origin-left">
                  {calc.icon}
                </div>
                <h3 class="text-2xl font-black text-slate-900 mb-4 group-hover:text-indigo-600 transition-colors">
                  {calc.titulo}
                </h3>
                <p class="text-slate-500 font-medium leading-relaxed">
                  {calc.description}
                </p>
                <div class="mt-auto pt-8 flex items-center text-indigo-600 font-bold">
                  Calcular ahora{" "}
                  <span class="ml-2 group-hover:translate-x-2 transition-transform">
                    →
                  </span>
                </div>
              </a>
            ))}

            {/* RENDERIZADO DE MUESTRA MASIVA (Solo si es la categoría Unidades) */}
            {cat.id === "unidades" &&
              unidadesDestacadas.map((u) => (
                <a
                  href={`/utiles/${u.slug}`}
                  class="group bg-slate-50 p-8 rounded-[3rem] border border-transparent hover:border-indigo-100 hover:bg-white shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 flex flex-col h-full card-calc"
                  data-keywords={(
                    u.titulo +
                    " " +
                    u.h1 +
                    " unidades"
                  ).toLowerCase()}
                >
                  <div class="text-5xl mb-6 opacity-80 group-hover:opacity-100">
                    ↔️
                  </div>
                  <h3 class="text-2xl font-black text-slate-900 mb-4">
                    {u.titulo}
                  </h3>
                  <p class="text-slate-500 font-medium italic">
                    Conversión de {u.h1}
                  </p>
                  <div class="mt-auto pt-8 flex items-center text-indigo-400 font-bold group-hover:text-indigo-600">
                    Ver conversor <span class="ml-2">→</span>
                  </div>
                </a>
              ))}
          </div>
        </div>
      ))
    }

    <div id="noResults" class="hidden text-center py-20">
      <div class="text-7xl mb-6">🛸</div>
      <h3 class="text-3xl font-black text-slate-800">
        No encontramos esa herramienta
      </h3>
      <p class="text-slate-500 text-lg">Pero podemos crearla. ¡Escribinos!</p>
    </div>
  </main>
</Layout>

<script>
  // Tu script de búsqueda actual funciona perfecto, no hace falta cambiarlo.
  // Solo asegúrate de que el selector sea el correcto.
</script>
