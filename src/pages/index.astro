---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mi Hub de Herramientas">
  <h1 class="text-4xl font-black text-center my-12 text-slate-800">
    Herramientas <span class="text-blue-600">SEO & Finanzas</span>
  </h1>

  <div class="grid md:grid-cols-2 gap-8 px-4 max-w-6xl mx-auto">
    <a
      href="/Calculadoras/porcentaje"
      class="p-8 border-2 rounded-3xl hover:border-blue-500 hover:shadow-2xl transition group bg-white block shadow-sm"
    >
      <h2
        class="text-2xl font-bold mb-2 group-hover:text-blue-600 text-slate-800"
      >
        📊 Calculadora PORCENTAJE
      </h2>
      <p class="text-slate-500 font-medium">Calculá impuestos rápido.</p>
    </a>

    <a
      href="/Calculadoras/prestamo"
      class="p-8 border-2 rounded-3xl hover:border-blue-500 hover:shadow-2xl transition group bg-white block shadow-sm"
    >
      <h2
        class="text-2xl font-bold mb-2 group-hover:text-blue-600 text-slate-800"
      >
        💸 Calculadora Prestamo
      </h2>
      <p class="text-slate-500 font-medium">Ideal para ofertas.</p>
    </a>
  </div>
</Layout>
