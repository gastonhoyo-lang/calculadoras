---
import FAQ from "../components/FAQ.astro";
import MenuMovil from "../components/MenuMovil.astro"; // <--- AGREGÁ ESTO
import { navigation } from "../data/navigation"; // <--- AGREGÁ ESTO
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Calculadoras financieras gratuitas: Simulá préstamos, calculá interés compuesto y tomá mejores decisiones con Chieffin.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://chieffin.com");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={`https://chieffin.com${Astro.url.pathname}`} />
    <title>{title} | Chieffin</title>
    <meta name="title" content={`${title} | Chieffin`} />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://chieffin.com/og-image.jpg" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta
      property="twitter:image"
      content="https://chieffin.com/og-image.jpg"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#2563eb" />
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Chieffin",
        url: "https://chieffin.com",
        potentialAction: {
          "@type": "SearchAction",
          target: "https://chieffin.com/?q={search_term_string}",
          "query-input": "required name=search_term_string",
        },
      })}
    />

    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js");
        });
      }
    </script>
  </head>

  <body class="bg-slate-50 text-slate-900 font-sans antialiased">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <nav
        class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between gap-4"
      >
        <a
          href="/"
          class="text-2xl font-black tracking-tight text-blue-600 shrink-0"
        >
          CHIEFFIN<span class="text-slate-400">.com</span>
        </a>

        <div class="hidden lg:flex gap-4 text-sm font-medium text-slate-600">
          {
            navigation.map((category) => (
              <div class="relative group">
                <button class="flex items-center gap-1 hover:text-blue-600 transition py-5 font-bold whitespace-nowrap">
                  {category.name}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3 h-3 text-slate-400 group-hover:text-blue-600 transition"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"
                    />
                  </svg>
                </button>

                <div class="absolute left-0 mt-0 w-56 bg-white border border-slate-200 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible group-hover:mt-2 transition-all duration-200 z-[60]">
                  <div class="p-2 max-h-[70vh] overflow-y-auto">
                    {category.links.map((link) => (
                      <a
                        href={link.href}
                        class="block px-4 py-2.5 text-sm text-slate-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition font-medium border-b border-slate-50 last:border-0"
                      >
                        {link.name}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <div class="flex items-center gap-2">
          <button
            id="favBtn"
            class="bg-slate-900 text-white px-3 py-2 sm:px-4 rounded-lg text-sm font-bold hover:bg-slate-800 transition flex items-center gap-2 shrink-0"
          >
            <span id="favIcon">⭐</span>
            <span class="hidden sm:inline">Favoritos</span>
          </button>

          <MenuMovil />
        </div>
      </nav>
    </header>

    <main class="min-h-[calc(100vh-160px)]">
      <slot />
      <FAQ />
    </main>

    <footer class="bg-white border-t border-slate-200 py-12 mt-20">
      <div
        class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-slate-500"
      >
        <div>
          <p class="font-bold text-lg mb-4 text-slate-900">Chieffin</p>
          <p>
            Herramientas diseñadas para ayudarte a entender mejor tus números y
            tomar decisiones informadas.
          </p>
        </div>
        <div>
          <p class="font-bold mb-4 text-slate-900">Categorías Populares</p>
          <ul class="space-y-2">
            <li>
              <a href="/finanzas/prestamo" class="hover:text-blue-600"
                >Préstamos</a
              >
            </li>
            <li>
              <a href="/finanzas/interes-compuesto" class="hover:text-blue-600"
                >Interés Compuesto</a
              >
            </li>
            <li>
              <a href="/hogar/hormigon" class="hover:text-blue-600"
                >Construcción</a
              >
            </li>
          </ul>
        </div>
        <div>
          <p class="font-bold mb-4 text-slate-900">Legal y Ayuda</p>
          <ul class="space-y-2">
            <li>
              <a href="/privacidad" class="hover:text-blue-600"
                >Política de Privacidad</a
              >
            </li>
            <li>
              <a href="/contacto" class="hover:text-blue-600"
                >Contacto y Sugerencias</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div
        class="max-w-6xl mx-auto px-4 mt-12 pt-8 border-t border-slate-100 text-center text-slate-400 text-xs"
      >
        &copy; {new Date().getFullYear()} Chieffin.com - Herramientas gratuitas para
        uso cotidiano.
      </div>
    </footer>

    <script is:inline>
      let deferredPrompt;
      const favBtn = document.getElementById("favBtn");
      const favIcon = document.getElementById("favIcon");

      const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
      const isiOS = /iPad|iPhone|iPod/.test(navigator.userAgent);

      window.addEventListener("beforeinstallprompt", (e) => {
        e.preventDefault();
        deferredPrompt = e;
        if (favBtn && favIcon) {
          favIcon.textContent = "📲";
          favBtn.innerHTML = "<span>📲</span> Instalar App";
          favBtn.classList.replace("bg-slate-900", "bg-blue-600");
        }
      });

      favBtn?.addEventListener("click", async () => {
        if (deferredPrompt) {
          deferredPrompt.prompt();
          await deferredPrompt.userChoice;
          deferredPrompt = null;
          return;
        }

        if (isiOS) {
          alert(
            'Para instalar en tu iPhone:\n\n1. Toca el botón "Compartir" (cuadrado con flecha).\n2. Selecciona "Agregar a inicio".',
          );
          return;
        }

        if (isMobile) {
          alert(
            '¡Guardanos en tu inicio!\n\nTocá los tres puntos (⋮) y seleccioná "Instalar aplicación" o "Agregar a pantalla de inicio".',
          );
          return;
        }

        const isMac = navigator.platform.toUpperCase().indexOf("MAC") >= 0;
        alert(
          `¡Guardanos en tus favoritos!\n\nPresioná ${isMac ? "Cmd + D" : "Ctrl + D"} para tenernos a mano.`,
        );
      <script is:inline>
  // Esta función se ejecuta cada vez que el usuario hace clic en un botón de calcular
  document.addEventListener('click', (e) => {
    // Si el clic fue en un botón de "Calcular" (buscamos por ID o clase)
    if (e.target.id?.includes('btn') || e.target.innerText.toLowerCase().includes('calcular')) {
      
      // Esperamos un milisegundo a que tus scripts actuales muestren el resultado
      setTimeout(() => {
        const resultBoxes = document.querySelectorAll('[id*="res"], [id*="Result"], .animate-in');
        
        resultBoxes.forEach(box => {
          if (!box.classList.contains('hidden') && !box.querySelector('.btn-share-auto')) {
            // Creamos el botón dinámicamente
            const btn = document.createElement('button');
            btn.className = "btn-share-auto mt-4 w-full bg-green-600 text-white font-bold py-3 px-4 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95";
            btn.innerHTML = `<span>Compartir en WhatsApp</span>`;
            
            btn.onclick = () => {
              const texto = box.innerText.replace(/[\n\r]+/g, '\n').trim();
              const msg = `📊 *Resultado de Chieffin*\n\n${texto}\n\n👉 ${window.location.href}`;
              window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
            };
            
            box.appendChild(btn);
          }
        });
      }, 100);
    }
  });
</script>
      });
    </script>
  </body>
</html>
