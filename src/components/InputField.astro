---
// src/components/InputField.astro
interface Props {
  label: string;
  id: string;
  placeholder?: string;
  unit?: string; // Por ejemplo: "%", "$", "años"
}

const { label, id, placeholder, unit } = Astro.props;
---

<div class="flex flex-col gap-2">
  <label for={id} class="text-sm font-semibold text-slate-700">
    {label}
  </label>
  <div class="relative">
    <input
      type="number"
      id={id}
      placeholder={placeholder}
      class="w-full p-3 border-2 border-slate-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all text-lg"
    />
    {
      unit && (
        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">
          {unit}
        </span>
      )
    }
  </div>
</div>
